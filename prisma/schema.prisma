// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Challenge {
id String @id @default(cuid())
title String
description String?

// Reference audio
referenceBlobUrl String
referenceDuration Float
bpm Float
key String

// Precomputed DSP snashop
referenceFeatures Json

// Daily rotation
activeDate DateTime @unique
isActive Boolean @default(true)

submissions Submission[]

// metadata
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}

model Submission{
id String @id @default(cuid())
challengeId String
challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

// audio
blobUrl String
duration Float

username String

// Score
overallScore Float
tempoScore Float
keySocre Float
rhythmScore Float
energyScore Float

processingTimeMs Int?

//metadata
createdAt DateTime @default(now())

// optimized leaderboard index
@@index([challengeId, overallScore(sort: Desc)])
}
