// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Challenge {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Reference audio
  blobUrl  String
  duration Float

  // Cached metadata (derived from referenceFeatures)
  bpm Float
  key String

  // Precomputed DSP snapshot
  referenceFeatures Json

  // Daily rotation
  activeDate DateTime @unique
  isActive   Boolean  @default(true)

  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id String @id @default(cuid())

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  blobUrl  String
  duration Float

  submissionFeatures Json

  username String

  overallScore Float
  tempoScore   Float
  keyScore     Float
  rhythmScore  Float
  energyScore  Float

  processingTimeMs Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // only one submission per user per challenge
  @@unique([challengeId, username])
  // optimized leaderboard index, order by the in case score is tied
  @@index([challengeId, overallScore(sort: Desc), createdAt])
}
