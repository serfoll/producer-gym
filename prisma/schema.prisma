// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Challenge {
  id                String       @id @default(cuid())
  title             String
  description       String?
  blobUrl           String
  duration          Float
  activeDate        DateTime     @unique
  referenceFeatures Json
  submissions       Submission[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Submission {
  id                String    @id @default(cuid())
  challengeId       String
  challenge         Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  blobUrl           String
  duration          Float
  username          String
  referenceFeatures Json
  overallScore      Float
  tempoScore        Float
  keyScore          Float
  rhythmScore       Float
  dynamicsScore     Float
  structureScore    Float
  spectralScore     Float
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // only one submission per user per challenge
  @@unique([challengeId, username])
  // optimized leaderboard index, order by the in case score is tied
  @@index([challengeId, overallScore(sort: Desc), createdAt])
}
